{
  "manifest_version": 3,
  "name": "Image Prompt Generator",
  "version": "1.0.0",
  "description": "右键识别网页图片并生成 AI 提示词",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.anthropic.com/*",
    "https://opencode.ai/*",
    "https://api.siliconflow.cn/*",
    "https://cloud.vtrix.ai/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "图片提示词生成器"
  }
}
